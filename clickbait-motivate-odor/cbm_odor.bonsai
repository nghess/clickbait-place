              <Builder xsi:type="ipy:PythonTransform">
                <ipy:Script>@returns(float)
def process(value):
    flip_state = value.Item1
    session_num = value.Item2[0]
    iti_bool = value.Item2[1]
    reward_state = value.Item2[2]
    active_target = value.Item2[3]
    trial_phase = str(value.Item2[4])


    if trial_phase == "platform" and not reward_state:
      if active_target is None:
          return float(1000)
      elif flip_state == 1 and iti_bool == False:
          return float(1.5)
      elif flip_state == 0 and iti_bool == False:
          return float(-1.5)
      else:
          return float(1000)
    else:
          return float(1000)</ipy:Script>
